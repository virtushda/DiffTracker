{
  "name": "diff-tracker",
  "displayName": "Diff Tracker",
  "description": "Visual file diff tracking - record and display changes in real-time",
  "version": "0.6.2",
  "publisher": "virtushda",
  "author": "virtushda (fork from TinyTigerPan (Fork from Wizyoung))",
  "icon": "resources/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/virtushda/DiffTracker.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:diffTracker.changesView",
    "onView:diffTracker.settingsView",
    "onCommand:diffTracker.toggleRecording",
    "onCommand:diffTracker.startRecording",
    "onCommand:diffTracker.stopRecording"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diffTracker",
          "title": "Diff Tracker",
          "icon": "resources/record-icon.svg"
        }
      ]
    },
    "views": {
      "diffTracker": [
        {
          "id": "diffTracker.changesView",
          "name": "Change Recording"
        },
        {
          "id": "diffTracker.settingsView",
          "name": "Settings"
        }
      ]
    },
    "configuration": {
      "title": "Diff Tracker",
      "properties": {
        "diffTracker.showDeletedLinesBadge": {
          "type": "boolean",
          "default": true,
          "description": "Show a badge indicating deleted lines"
        },
        "diffTracker.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens actions (Revert/Keep) above change blocks"
        },
        "diffTracker.highlightAddedLines": {
          "type": "boolean",
          "default": true,
          "description": "Highlight added lines with green background"
        },
        "diffTracker.highlightModifiedLines": {
          "type": "boolean",
          "default": true,
          "description": "Highlight modified lines with blue background"
        },
        "diffTracker.highlightWordChanges": {
          "type": "boolean",
          "default": true,
          "description": "Highlight word-level changes within modified lines"
        },
        "diffTracker.defaultOpenMode": {
          "type": "string",
          "default": "webview",
          "enum": [
            "webview",
            "inline",
            "sideBySide",
            "original",
            "splitOriginalWebview"
          ],
          "enumDescriptions": [
            "Open interactive webview diff panel",
            "Open inline diff editor (read-only)",
            "Open VS Code side-by-side diff editor",
            "Open original file directly",
            "Open split view: left original file, right webview diff panel"
          ],
          "description": "Default open mode when clicking a changed file in Diff Tracker"
        },
        "diffTracker.openWebviewBeside": {
          "type": "boolean",
          "default": false,
          "description": "When opening Webview diff, place it in a side editor group instead of the current one"
        },
        "diffTracker.showFullFilePaths": {
          "type": "boolean",
          "default": false,
          "description": "Show project-relative file paths in the Change Recording tree instead of only the file name"
        },
        "diffTracker.confirmReversions": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation dialog before reverting all changes or reverting all changes in a file"
        },
        "diffTracker.useGitIgnoreExcludes": {
          "type": "boolean",
          "default": true,
          "description": "Apply ignore rules from .gitignore files and .git/info/exclude"
        },
        "diffTracker.useBuiltInExcludes": {
          "type": "boolean",
          "default": true,
          "description": "Apply built-in ignore rules for common folders like .git, node_modules, dist, and coverage"
        },
        "diffTracker.useVSCodeExcludes": {
          "type": "boolean",
          "default": true,
          "description": "Apply VS Code exclude settings from files.watcherExclude, search.exclude, and files.exclude"
        },
        "diffTracker.watchExclude": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional ignore patterns for file watching (one pattern per entry, gitignore-style)"
        },
        "diffTracker.onlyTrackVSCodeChanges": {
          "type": "boolean",
          "default": false,
          "deprecationMessage": "Deprecated. Use diffTracker.onlyTrackAutomatedChanges instead.",
          "description": "Deprecated alias for automation-only tracking."
        },
        "diffTracker.onlyTrackAutomatedChanges": {
          "type": "boolean",
          "default": false,
          "description": "Only track automated changes. Manual typing in VS Code is ignored; external tool edits and tagged agent/extension edits are still recorded."
        }
      }
    },
    "commands": [
      {
        "command": "diffTracker.toggleRecording",
        "title": "Toggle Recording",
        "category": "Diff Tracker",
        "icon": "$(record)"
      },
      {
        "command": "diffTracker.startRecording",
        "title": "Start Recording",
        "category": "Diff Tracker",
        "icon": "$(record)"
      },
      {
        "command": "diffTracker.stopRecording",
        "title": "Stop Recording",
        "category": "Diff Tracker",
        "icon": "$(debug-stop)"
      },
      {
        "command": "diffTracker.showDiffs",
        "title": "Show Diffs",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.clearDiffs",
        "title": "Clear Diffs",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.revertAllChanges",
        "title": "Revert All Changes",
        "category": "Diff Tracker",
        "icon": "$(discard)"
      },
      {
        "command": "diffTracker.keepAllChanges",
        "title": "Accept All Changes",
        "category": "Diff Tracker",
        "icon": "$(check)"
      },
      {
        "command": "diffTracker.revertFile",
        "title": "Revert File",
        "category": "Diff Tracker",
        "icon": "$(discard)"
      },
      {
        "command": "diffTracker.showInlineDiff",
        "title": "Show Inline Diff",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.showSideBySideDiff",
        "title": "Show Side-by-Side Diff",
        "category": "Diff Tracker",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "diffTracker.showSideBySideDiffActive",
        "title": "Show Side-by-Side Diff (Active)",
        "category": "Diff Tracker",
        "icon": {
          "dark": "resources/diff-sbs-dark.svg",
          "light": "resources/diff-sbs-light.svg"
        }
      },
      {
        "command": "diffTracker.showInlineDiffActive",
        "title": "Show Inline Diff (Active)",
        "category": "Diff Tracker",
        "icon": {
          "dark": "resources/diff-inline-dark.svg",
          "light": "resources/diff-inline-light.svg"
        }
      },
      {
        "command": "diffTracker.revertBlock",
        "title": "Revert Block",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.keepBlock",
        "title": "Keep Block",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.goToBlock",
        "title": "Go to Block",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.openOriginalFile",
        "title": "Open Original File",
        "category": "Diff Tracker",
        "icon": "$(go-to-file)"
      },
      {
        "command": "diffTracker.openDiffDefault",
        "title": "Open with Diff Tracker",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.revertAllBlocksInFile",
        "title": "Revert All Changes in File",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.keepAllBlocksInFile",
        "title": "Accept All Changes in File",
        "category": "Diff Tracker",
        "icon": "$(check)"
      },
      {
        "command": "diffTracker.showWebviewDiff",
        "title": "Show Webview Diff",
        "category": "Diff Tracker",
        "icon": "$(preview)"
      },
      {
        "command": "diffTracker.showWebviewDiffActive",
        "title": "Show Webview Diff (Active)",
        "category": "Diff Tracker",
        "icon": "$(preview)"
      },
      {
        "command": "diffTracker.showOriginalAndWebviewSplit",
        "title": "Show Split: Original | Webview",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.selectDefaultOpenMode",
        "title": "Select Default Open Mode",
        "category": "Diff Tracker"
      },
      {
        "command": "diffTracker.editWatchExcludes",
        "title": "Edit Watch Ignores",
        "category": "Diff Tracker"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "diffTracker.openOriginalFile",
          "when": "view == diffTracker.changesView && viewItem == changedFile",
          "group": "inline"
        },
        {
          "command": "diffTracker.showSideBySideDiff",
          "when": "view == diffTracker.changesView && viewItem == changedFile",
          "group": "inline"
        },
        {
          "command": "diffTracker.keepAllBlocksInFile",
          "when": "view == diffTracker.changesView && viewItem == changedFile",
          "group": "inline"
        },
        {
          "command": "diffTracker.revertFile",
          "when": "view == diffTracker.changesView && viewItem == changedFile",
          "group": "inline"
        },
        {
          "command": "diffTracker.showWebviewDiff",
          "when": "view == diffTracker.changesView && viewItem == changedFile",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "diffTracker.openDiffDefault",
          "when": "resourceScheme == file && diffTracker.isRecording",
          "group": "2_main@1"
        }
      ],
      "view/title": [
        {
          "command": "diffTracker.startRecording",
          "when": "view == diffTracker.changesView && !diffTracker.isRecording",
          "group": "navigation"
        },
        {
          "command": "diffTracker.stopRecording",
          "when": "view == diffTracker.changesView && diffTracker.isRecording",
          "group": "navigation"
        },
        {
          "command": "diffTracker.clearDiffs",
          "when": "view == diffTracker.changesView",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "diffTracker.showSideBySideDiffActive",
          "when": "resourceScheme == file && diffTracker.isRecording",
          "group": "navigation"
        },
        {
          "command": "diffTracker.showInlineDiffActive",
          "when": "resourceScheme == file && diffTracker.isRecording",
          "group": "navigation"
        },
        {
          "command": "diffTracker.showWebviewDiffActive",
          "when": "resourceScheme == file && diffTracker.isRecording",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "diffTracker.toggleRecording",
        "key": "shift+alt+d",
        "mac": "shift+option+d"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run build:webview",
    "build:webview": "node esbuild.webview.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test:webview-anchors": "node test/webview-annotation-mapping.mjs",
    "test:similarity-pairing": "node test/similarity-pairing.mjs",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.x",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "@pierre/diffs": "^1.0.10",
    "diff": "^8.0.3",
    "ignore": "^5.3.2"
  }
}
